[Unit]
Description=quillrag (FastAPI + Uvicorn) — Independent RAG Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/workspace/quillrag
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/root/workspace/quillrag
ExecStart=/root/workspace/quillrag/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
